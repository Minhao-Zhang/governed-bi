# Copy to `.env` (git-ignored) for local runs. governed-bi reads this file at the
# repo root on import and fills in any variable NOT already set in your shell -
# a real environment variable always wins, so `.env` is a fallback, never an
# override. Never commit a real key.

# The OpenAI API key (name configurable via [models].api_key_env in governed_bi.toml).
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown):
# GOVERNED_BI_CONFIG=governed_bi.toml
# GOVERNED_BI_CORPUS=corpus
# GOVERNED_BI_DB=beer_factory
# GOVERNED_BI_SQLITE=data/bird/beer_factory.sqlite
