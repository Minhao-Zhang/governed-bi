# Secrets and third-party toggles only. Copy to `.env` (git-ignored) for local runs.
#
# Policy (models, datasource kind, corpus path, serve flags) lives in
# governed_bi.toml, with optional overrides in governed_bi.local.toml.
# This file only supplies secret *values* (and framework tracing switches that
# LangChain/Langfuse read from the environment). A real shell environment
# variable always wins over `.env`.

# Named by [models].api_key_env in governed_bi.toml (default OPENAI_API_KEY).
OPENAI_API_KEY=sk-...

# Named by [datasource].dsn_env when kind is postgres/redshift. Example for the
# BIRD-Obfuscation renamed+decoy instance (local docker, port 5435):
# PG_RENAME_DECOY_DSN=host=127.0.0.1 port=5435 dbname=bird user=bird password=bird

# ---------------------------------------------------------------------------
# Optional: LangSmith (native LangChain/LangGraph tracing — no extra package)
# ---------------------------------------------------------------------------
# Either tracing toggle works; LANGSMITH_TRACING is the current LangSmith name,
# LANGCHAIN_TRACING_V2 is the legacy alias. Both need LANGSMITH_API_KEY.
# LANGSMITH_TRACING=true
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=governed-bi

# ---------------------------------------------------------------------------
# Optional: Langfuse (LangChain callback — installed by default; no extra needed)
# ---------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
