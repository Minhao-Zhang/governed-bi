{
  "openapi": "3.1.0",
  "info": {
    "title": "governed-bi API",
    "summary": "Governed NL2SQL serve flow + corpus/schema/audit, as JSON.",
    "version": "0.1.0"
  },
  "paths": {
    "/capabilities": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Capabilities",
        "description": "What this backend can do — the UI adapts its affordances to this.",
        "operationId": "capabilities_capabilities_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilitiesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/livez": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Livez",
        "description": "Process liveness (no corpus work). Use /health for corpus status.",
        "operationId": "livez_livez_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Livez Livez Get"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Health",
        "description": "Corpus health: asset counts, CI status, and the triage flags.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/schema": {
      "get": {
        "tags": [
          "schema"
        ],
        "summary": "Schema",
        "description": "Every table with its columns (types, roles, governance flags).",
        "operationId": "schema_schema_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/TableResponse"
                  },
                  "type": "array",
                  "title": "Response Schema Schema Get"
                }
              }
            }
          }
        }
      }
    },
    "/graph": {
      "get": {
        "tags": [
          "schema"
        ],
        "summary": "Graph",
        "description": "Table-relationship graph for the ER view (nodes + join edges).",
        "operationId": "graph_graph_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchemaGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/knowledge-graph": {
      "get": {
        "tags": [
          "schema"
        ],
        "summary": "Knowledge Graph",
        "description": "Full corpus knowledge graph: every asset a node, typed relationships as\nedges. Filter/layer by ``node.kind`` (e.g. tables + joins for the ER view).",
        "operationId": "knowledge_graph_knowledge_graph_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeGraphResponse"
                }
              }
            }
          }
        }
      }
    },
    "/corpus/assets": {
      "get": {
        "tags": [
          "corpus"
        ],
        "summary": "Corpus Assets",
        "description": "Non-table assets (metrics/terms/joins/rules/few-shots/negatives).",
        "operationId": "corpus_assets_corpus_assets_get",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "join",
                    "metric",
                    "term",
                    "rule",
                    "few_shot",
                    "negative_example"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Type"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AssetRowResponse"
                  },
                  "title": "Response Corpus Assets Corpus Assets Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/skills": {
      "get": {
        "tags": [
          "corpus"
        ],
        "summary": "Skills",
        "description": "Curated skills (rendered markdown bodies).",
        "operationId": "skills_skills_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SkillResponse"
                  },
                  "type": "array",
                  "title": "Response Skills Skills Get"
                }
              }
            }
          }
        }
      }
    },
    "/corpus/edit": {
      "post": {
        "tags": [
          "corpus"
        ],
        "summary": "Corpus Edit",
        "description": "Validate a corpus asset and, in dev, write it to the YAML tree.\n\nGated on ``capabilities.can_edit`` (403 otherwise). The asset is schema-\nvalidated (422 on a bad shape) then reference-checked against the rest of\nthe corpus; findings block the write and are returned with the diff so the\neditor can fix them. Prod PR mode is deferred; the request shape is stable.",
        "operationId": "corpus_edit_corpus_edit_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EditResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/chat": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat",
        "description": "Answer one turn. Working memory is rebuilt from ``history`` (the API is\nstateless); the caller persists the transcript.",
        "operationId": "chat_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
